# ─── Clerk Auth ─────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs — keep these as-is unless you change your routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Get from https://cloud.mongodb.com → your cluster → Connect → Drivers
# Free tier (M0) works fine for development
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lexlens?retryWrites=true&w=majority

# ─── AI Providers ────────────────────────────────────────────────────────────
# Primary: Google Gemini Flash — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback: Groq (free tier available) — https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
